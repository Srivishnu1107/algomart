generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

// Required for creating a User: id, name, email, image, cart (optional JSON string)
model User {
    id    String @id
    name  String
    email String
    image String
    cart  Json   @default("{}")
    isPro Boolean @default(false)
    proMemberSince DateTime?
    proExpiresAt        DateTime?  // Pro valid until this date (1-month plan)
    stripeCustomerId    String?   // For subscription billing and card display
    stripeSubscriptionId String?   // For cancel at period end

    // Relations
    proPayments     ProPayment[]
    ratings         Rating[]
    Address         Address[]
    stores          Store[]
    buyerOrders     Order[]   @relation("BuyerRelation")
    wishlist        Wishlist[]
    followingStores StoreFollow[]
    fashionProfiles FashionProfile[]
}

model FashionProfile {
    id          String   @id @default(cuid())
    userId      String
    name        String
    height      Int      // cm
    weight      Int      // kg
    bodyType    String   @default("Regular")
    ageInterval String?
    gender      String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

// Required for creating a Product: name, description, mrp, price, images, category, storeId
model Product {
    id          String   @id @default(cuid())
    name        String
    description String   @default("")
    mrp         Float?   // Legacy field - maps to actual_price, nullable for drafts
    price       Float?   // Legacy field - maps to offer_price, nullable for drafts
    images      String[] @default([])
    category    String   @default("")
    brand       String?  // Product brand (e.g. Samsung, Sony) for filtering and display
    productType ProductType @default(electronics)
    inStock     Boolean  @default(true)
    storeId     String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    // New business intelligence fields
    actual_price        Float?   // Required for new products, nullable for backward compatibility
    offer_price         Float?   // Required for new products, nullable for backward compatibility
    cost_price          Float?
    stock_quantity      Int      @default(0)
    low_stock_threshold Int      @default(5)
    sku                 String?  @unique
    commission_rate     Float    @default(0.10)
    commission_amount   Float?   // Computed server-side
    net_earnings        Float?   // Computed server-side (offer_price - commission_amount)
    net_profit          Float?   // Computed server-side (net_earnings - cost_price)
    is_draft            Boolean  @default(true)
    status              ProductStatus @default(draft)
    adminClearedSuspicion Boolean @default(false)
    
    // Legacy camelCase fields (to be migrated, then removed)
    commissionRate      Float?   @map("commissionRate")
    isDraft             Boolean? @map("isDraft")
    lowStockThreshold   Int?     @map("lowStockThreshold")
    stockQuantity       Int?     @map("stockQuantity")

    // Relations
    store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
    orderItems OrderItem[]
    rating     Rating[]
    wishlist   Wishlist[]
    reports   Report[]
}

model Wishlist {
    id        String    @id @default(cuid())
    userId    String
    productId String
    storeType StoreType @default(electronics)
    createdAt DateTime  @default(now())

    // Relations
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([userId, productId])
    @@index([userId, storeType])
}

enum OrderStatus {
    ORDER_PLACED
    PROCESSING
    SHIPPED
    DELIVERED
    CANCELLATION_REQUESTED
    RETURN_REQUESTED
    RETURNED
    CANCELLED
}

enum PaymentMethod {
    COD
    STRIPE
}

// Required for creating an Order: total, userId, storeId, addressId, isPaid, paymentMethod, isCouponUsed, coupon (JSON), orderItems (nested)
model Order {
    id            String        @id @default(cuid())
    total         Float
    status        OrderStatus   @default(ORDER_PLACED)
    userId        String
    storeId       String
    addressId     String
    isPaid        Boolean       @default(false)
    paymentMethod PaymentMethod
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    isCouponUsed       Boolean       @default(false)
    coupon             Json          @default("{}")
    cancellationReason   String?
    vendorStatusMessage  String?  // Vendor message when rejecting cancel/return (reason shown to customer)
    orderItems           OrderItem[]

    // Relations
    user    User    @relation("BuyerRelation", fields: [userId], references: [id])
    store   Store   @relation(fields: [storeId], references: [id])
    address Address @relation(fields: [addressId], references: [id])
}

// Required for creating an OrderItem: orderId, productId, quantity, price
model OrderItem {
    orderId   String
    productId String
    quantity  Int
    price     Float

    // Relations
    order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id])

    @@id([orderId, productId])
}

// Required for creating a Rating: rating, review, userId, productId
model Rating {
    id        String   @id @default(cuid())
    rating    Int
    review    String
    userId    String
    productId String
    orderId   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([userId, productId, orderId])
}

// Required for creating an Address: userId, name, email, street, city, state, zip, country, phone; optional latitude, longitude
model Address {
    id        String   @id @default(cuid())
    userId    String
    label     String?  // "home" | "work" | "other"
    name      String
    email     String
    street    String
    city      String
    state     String
    zip       String
    country   String
    phone     String
    latitude  Float?
    longitude Float?
    isArchived Boolean @default(false)
    createdAt DateTime @default(now())

    // Relations
    Order Order[]
    user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Required for creating a Coupon: code, description, discount, forNewUser, isPublic, expiresAt
model Coupon {
    code        String   @id
    description String
    discount    Float
    forNewUser  Boolean
    forMember   Boolean  @default(false)
    isPublic    Boolean
    expiresAt   DateTime
    createdAt   DateTime @default(now())
    storeType   StoreType @default(electronics)

    @@index([storeType])
}

enum StoreType {
    electronics
    fashion
}

enum ProductType {
    electronics
    fashion
}

enum ProductStatus {
    active
    inactive
    draft
}

// Required for creating a Store: userId, name, username, email, contact, logo, description, address (optional: , status, isActive)
model Store {
    id          String   @id @default(cuid())
    userId      String
    name        String
    description String
    username    String   @unique
    address     String
    status      String   @default("pending")
    isActive    Boolean  @default(false)
    logo        String
    banner      String?  // Optional store cover image for homepage
    email       String
    contact     String
    storeType   StoreType @default(electronics)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    lastActiveAt DateTime?  // Updated when vendor publishes a product; used to find inactive stores

    Product    Product[]
    Order      Order[]
    user       User          @relation(fields: [userId], references: [id])
    followers  StoreFollow[]
    businessOverview BusinessOverview?
    demandPrediction   VendorDemandPrediction?
    salesInsight       VendorSalesInsight?
    returnPredictor    VendorReturnPredictor?
    competitorInsight VendorCompetitorInsight?
    trustAnalysis      VendorTrustAnalysis?
    homeBanners       VendorHomeBanner[]
}

// Vendor home page banner: name, image, optional whole-banner link, and customizable CTA buttons. Multiple per store.
model VendorHomeBanner {
    id         String   @id @default(cuid())
    storeId    String
    name       String   @default("Banner") // Display name for the banner
    imageUrl   String
    bannerLink String?  // When user clicks the banner (not on a button), navigate here
    buttons    Json     @default("[]") // [{ label, link, backgroundColor, textColor, size }], size: sm | md | lg
    sortOrder  Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@index([storeId])
}

model BusinessOverview {
    id              String    @id @default(cuid())
    storeId         String    @unique
    storeType       StoreType @default(electronics)
    overviewInsight String    @db.Text
    issueInsight    String    @db.Text
    lastAnalyzedAt  DateTime  @default(now())

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@index([storeType])
    @@map("Business overview")
}

// ----- Vendor AI Business Insights (structured JSON, stored in Neon) -----
// Run type: initial_analysis (first run), relook_analysis (refresh with latest data). Result stored as snapshot.

model VendorDemandPrediction {
    id         String     @id @default(cuid())
    storeId    String
    storeType  StoreType  @default(electronics)
    payload    Json       // { demandTrends[], restockSuggestions[], overstockRisks[], summary }
    runType    String     // "initial_analysis" | "relook_analysis"
    analyzedAt DateTime  @default(now())

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@unique([storeId])
    @@index([storeId])
    @@index([storeType])
}

model VendorSalesInsight {
    id         String     @id @default(cuid())
    storeId    String
    storeType  StoreType  @default(electronics)
    payload    Json       // { summary, top_reasons[], actionable_suggestions[] }
    runType    String
    analyzedAt DateTime   @default(now())

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@unique([storeId])
    @@index([storeId])
    @@index([storeType])
}

model VendorReturnPredictor {
    id         String     @id @default(cuid())
    storeId    String
    storeType  StoreType  @default(electronics)
    payload    Json       // { products: [{ productId, risk, likelyCauses[] }], summary }
    runType    String
    analyzedAt DateTime   @default(now())

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@unique([storeId])
    @@index([storeId])
    @@index([storeType])
}

model VendorCompetitorInsight {
    id         String     @id @default(cuid())
    storeId    String
    storeType  StoreType  @default(electronics)
    payload    Json       // graph-friendly: series[], comparisons[], summary
    runType    String
    analyzedAt DateTime   @default(now())

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@unique([storeId])
    @@index([storeId])
    @@index([storeType])
}

model VendorTrustAnalysis {
    id         String     @id @default(cuid())
    storeId    String     @unique
    storeType  StoreType  @default(electronics)
    summary    String     @db.Text
    tone       String     // 'positive', 'neutral', 'caution'
    highlights Json       // Array of highlight strings
    analyzedAt DateTime   @default(now())
    updatedAt  DateTime   @updatedAt

    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
    @@index([storeId])
    @@index([storeType])
}

model Report {
    id           String   @id @default(cuid())
    reporterId   String   // Clerk userId
    productId    String
    reasonType   String   // inappropriate, fake, wrong_info, copyright, spam, other
    customReason String?  @db.Text
    createdAt    DateTime @default(now())

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@index([productId])
    @@index([createdAt])
}

// Single row: latest AI-generated reports overview (groups with counts, reasons, productId, price, etc.)
model ReportsAiOverview {
    id         String   @id @default(cuid())
    payload    Json     // { groups: [{ representativeName, totalCount, shortReason, storeBreakdown, representativeProductId, representativeStoreType, price, createdAt }] }
    analyzedAt DateTime @default(now())
}

model StoreFollow {
    id        String   @id @default(cuid())
    userId    String
    storeId   String
    createdAt DateTime @default(now())

    // Relations
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

    @@unique([userId, storeId])
    @@index([userId])
    @@index([storeId])
}

// Pro membership one-time payments (Stripe Checkout)
model ProPayment {
    id              String   @id @default(cuid())
    userId          String
    stripeSessionId String   @unique
    amount          Int      // in paise
    currency        String   @default("inr")
    paidAt          DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model AssistantConfig {
    id        String   @id @default(cuid())
    key       String   @unique
    value     String   @db.Text
    updatedAt DateTime @updatedAt
}

// ----- Admin–Vendor Chat (MVP) -----
enum ChatSenderRole {
    admin
    vendor
}

// One conversation per vendor; all admins share the same thread. Message.senderId identifies which admin sent.
model Conversation {
    id            String    @id @default(uuid())
    vendorId      String    @unique
    createdAt     DateTime  @default(now())
    lastMessageAt DateTime?

    messages Message[]

    @@index([vendorId])
}

model Message {
    id             String         @id @default(uuid())
    conversationId String
    senderId       String
    senderRole     ChatSenderRole
    content        String         @db.Text
    messageType    String         @default("normal")
    isRead         Boolean        @default(false)
    createdAt      DateTime       @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([conversationId, createdAt])
}

// ----- Vendor–Vendor Chat -----
model VendorConversation {
    id            String    @id @default(uuid())
    vendor1Id     String    // Clerk user id; must be < vendor2Id for uniqueness
    vendor2Id     String
    createdAt     DateTime  @default(now())
    lastMessageAt DateTime?

    messages VendorMessage[]

    @@unique([vendor1Id, vendor2Id])
    @@index([vendor1Id])
    @@index([vendor2Id])
}

model VendorMessage {
    id             String   @id @default(uuid())
    conversationId String
    senderId       String
    content        String   @db.Text
    createdAt      DateTime @default(now())

    conversation VendorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([conversationId, createdAt])
}

// ----- Admin–Admin Chat -----
model AdminConversation {
    id            String    @id @default(uuid())
    admin1Id      String    // Clerk user id; must be < admin2Id for uniqueness
    admin2Id      String
    createdAt     DateTime  @default(now())
    lastMessageAt DateTime?

    messages AdminMessage[]

    @@unique([admin1Id, admin2Id])
    @@index([admin1Id])
    @@index([admin2Id])
}

model AdminMessage {
    id             String   @id @default(uuid())
    conversationId String
    senderId       String
    content        String   @db.Text
    createdAt      DateTime @default(now())

    conversation AdminConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([conversationId, createdAt])
}

// User hides a conversation from their list (other participant still sees it). hiddenAt = when they hid; messages after this are shown when conversation reappears.
model HiddenConversation {
    id             String   @id @default(cuid())
    userId         String
    conversationId String
    type           String   // "admin_vendor" | "vendor_vendor" | "admin_admin"
    hiddenAt       DateTime @default(now()) // only show messages after this when they reopen
    createdAt      DateTime @default(now())

    @@unique([userId, conversationId])
    @@index([userId])
}

// ----- User behavior for AI recommendations (electronics vs fashion separate) -----
// Events: product_view, time_on_page, add_to_cart, purchase, wishlist, search, click, category_browse
model UserBehaviorEvent {
    id         String   @id @default(cuid())
    visitorId  String   // Anonymous cookie/localStorage id; used when userId is null
    userId     String?  // Clerk userId when logged in (optional)
    category   String   // "electronics" | "fashion" - data collected separately per vertical
    eventType  String   // product_view | time_on_page | add_to_cart | purchase | wishlist | search | click | category_browse
    productId  String?  // For product_view, time_on_page, add_to_cart, purchase, wishlist, click
    payload    Json     @default("{}") // e.g. { timeSpentSeconds, searchQuery, categoryName }
    createdAt  DateTime @default(now())

    @@index([visitorId, category])
    @@index([userId, category])
    @@index([visitorId, category, eventType])
    @@index([userId, category, eventType])
    @@index([createdAt])
}

// Cached AI recommendations per visitor/user per category; refreshed at most once per day
model UserRecommendation {
    id          String   @id @default(cuid())
    visitorId   String
    userId      String?
    category    String   // "electronics" | "fashion"
    productIds  String[] @default([]) // Ordered list of recommended product IDs
    lastUpdated DateTime @default(now())

    @@unique([visitorId, category])
    @@index([userId, category])
    @@index([lastUpdated])
}

// Track which notices an admin has viewed to dim/unbold them
model AdminNoticeView {
    id          String   @id @default(cuid())
    adminUserId String
    noticeType  String
    itemId      String
    viewedAt    DateTime @default(now())

    @@unique([adminUserId, noticeType, itemId])
    @@index([adminUserId])
}
